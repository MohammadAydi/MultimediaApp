<Application x:Class="AudioCompressionApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AudioCompressionApp.Converters">
    <Application.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <!-- 1. Color tokens (must come first — Controls.xaml references them) -->
                <ResourceDictionary Source="Themes/Colors.xaml" />

                <!-- 2. Control styles -->
                <ResourceDictionary Source="Themes/Controls.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <!--
                Application-level converter singletons.
                Windows/UserControls can also declare them locally, but
                putting them here means they're available everywhere.
            -->
            <conv:BoolToVisibilityConverter  x:Key="AppBoolToVisibility" />
            <conv:NullToVisibilityConverter  x:Key="AppNullToVisibility" />
            <conv:InverseBoolConverter       x:Key="AppInverseBool" />
            <conv:ProgressToPercentConverter x:Key="AppProgressToPercent" />
            <conv:NullToBoolConverter        x:Key="AppNullToBool" />
            <conv:StringToVisibilityConverter x:Key="AppStringToVisibility" />

        </ResourceDictionary>

    </Application.Resources>
</Application>