<Window x:Class="AudioCompressionApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Compression App"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="15">

        <Grid.RowDefinitions>

            <!-- fix height 70 -->
            <RowDefinition Height="70" />
            <!-- take three part of the remaining space -->
            <RowDefinition Height="3*" />
            <RowDefinition Height="170" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />

        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Margin="0,0,0,10"
                Padding="15">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Button Content="Open Audio"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Command="{Binding OpenAudioCommand}" />

                <Button Content="Play"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Command="{Binding PlayCommand}" />

                <Button Content="Compress"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Command="{Binding CompressCommand}" />

                <Button Content="Stop"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Command="{Binding StopCommand}" />

                <Button Content="Reset"
                        Width="100"
                        Height="40"
                        Command="{Binding ResetCommand}" />

                <TextBlock Text="Audio Compression System"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="30,0,0,0"
                           VerticalAlignment="Center" />

            </StackPanel>

        </Border>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />

            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10"
                    Margin="0,0,10,0"
                    AllowDrop="True"
                    Drop="FileDropBorder_OnDrop"
                    DragEnter="FileDropBorder_OnDragEnter">

                <Grid>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <TextBlock Text="🎵"
                                   FontSize="72"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20" />

                        <TextBlock Text="Drag &amp; Drop Audio File Here"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />

                        <TextBlock Text="Supported: WAV, MP3"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="16"
                                   Margin="0,15,0,0"
                                   HorizontalAlignment="Center" />

                    </StackPanel>

                </Grid>

            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="20">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="Compression Settings"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,25" />

                        <TextBlock Text="Algorithm"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="15" />

                        <ComboBox ItemsSource="{Binding Algorithms}"
                                  SelectedItem="{Binding SelectedAlgorithm}"
                                  DisplayMemberPath="Name"
                                  Margin="0,10,0,25"
                                  Height="35" />

                        <TextBlock Text="Sample Rate"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="15" />

                        <Slider Minimum="8000"
                                Maximum="48000"
                                TickFrequency="4000"
                                IsSnapToTickEnabled="True"
                                Value="{Binding SelectedSampleRate}"
                                Margin="0,10,0,0" />

                        <TextBlock
                            Text="{Binding SelectedSampleRate,
                                      StringFormat={}{0:F0} Hz}"
                            Foreground="{StaticResource TextBrush}"
                            FontSize="16"
                            Margin="0,5,0,25" />

                        <TextBlock Text="Quantization Levels"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="15" />

                        <Slider Minimum="2"
                                Maximum="32"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Value="{Binding QuantizationLevels}"
                                Margin="0,10,0,0" />

                        <TextBlock
                            Text="{Binding QuantizationLevels,
                                      StringFormat={}{0:F0} Bit}"
                            Foreground="{StaticResource TextBrush}"
                            FontSize="16"
                            Margin="0,5,0,0" />

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Margin="0,10,0,10"
                Padding="20">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />

                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="File Name"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="14" />

                    <TextBlock
                        Text="{Binding FileName,
                  TargetNullValue=No File Loaded}"
                        Foreground="{StaticResource TextBrush}"
                        FontSize="22"
                        FontWeight="Bold"
                        Margin="0,8,0,0" />

                </StackPanel>

                <StackPanel Grid.Column="1">

                    <TextBlock Text="Sample Rate"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="14" />

                    <TextBlock Text="{Binding SampleRate}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />

                </StackPanel>

                <StackPanel Grid.Column="2">

                    <TextBlock Text="Channels"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="14" />

                    <TextBlock Text="{Binding Channels}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />

                </StackPanel>

                <StackPanel Grid.Column="3">

                    <TextBlock Text="Bit Depth"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="14" />

                    <TextBlock Text="{Binding BitsPerSample}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />

                </StackPanel>

            </Grid>

        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Margin="0,0,0,10"
                Padding="20">

            <StackPanel>

                <TextBlock Text="Compression Progress"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,20" />

                <ProgressBar Height="35"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding CompressionProgress}" />

                <TextBlock Text="{Binding CompressionProgress, StringFormat={}{0:F0}%}"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           Margin="0,15,0,0"
                           HorizontalAlignment="Center" />

            </StackPanel>

        </Border>

        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Padding="20">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />

                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="Compression Ratio"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="16" />

                    <TextBlock Text="{Binding CompressionRatio}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="32"
                               FontWeight="Bold"
                               Margin="0,10,0,0" />

                </StackPanel>

                <StackPanel Grid.Column="1">

                    <TextBlock Text="Processing Speed"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="16" />

                    <TextBlock Text="{Binding ProcessingSpeed}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="32"
                               FontWeight="Bold"
                               Margin="0,10,0,0" />

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>