<Window x:Class="AudioCompressionApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Compression App"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="15">

        <Grid.RowDefinitions>

            <RowDefinition Height="70"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>

        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2D2D30"
                CornerRadius="10"
                Margin="0,0,0,10"/>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>

            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#2D2D30"
                    CornerRadius="10"
                    Margin="0,0,10,0"/>

            <Border Grid.Column="1"
                    Background="#2D2D30"
                    CornerRadius="10"/>

        </Grid>

        <Border Grid.Row="2"
                Background="#2D2D30"
                CornerRadius="10"
                Margin="0,10,0,10"/>

        <Border Grid.Row="3"
                Background="#2D2D30"
                CornerRadius="10"
                Margin="0,0,0,10"/>

        <Border Grid.Row="4"
                Background="#2D2D30"
                CornerRadius="10"/>

    </Grid>

</Window>