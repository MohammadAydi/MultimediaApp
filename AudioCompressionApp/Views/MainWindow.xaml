<Window x:Class="AudioCompressionApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AudioCompressionApp.ViewModels"
        xmlns:conv="clr-namespace:AudioCompressionApp.Converters"
        Style="{StaticResource Style.Window}"
        Title="AudioPress"
        Width="1280"
        Height="820">

    <!-- ── Converters ──────────────────────────────────────── -->
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:ProgressToPercentConverter x:Key="ProgressToPercent" />

        <!-- Formats the waveform icon path used in the drop zone -->
        <Style x:Key="Style.DropIcon" TargetType="Path">
            <Setter Property="Fill" Value="{StaticResource Brush.TextMuted}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
    </Window.Resources>

    <!-- =========================================================
         ROOT GRID
         Col 0: left sidebar (navigation + logo)
         Col 1: main content area
    ========================================================== -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- =====================================================
             LEFT SIDEBAR
        ====================================================== -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo / App name -->
                <Border DockPanel.Dock="Top" Padding="24,28,24,24">
                    <StackPanel>
                        <!-- Waveform icon (pure XAML geometry) -->
                        <Canvas Width="32" Height="20" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Rectangle Canvas.Left="0" Canvas.Top="8" Width="4" Height="4"
                                       Fill="{StaticResource Brush.Accent}" RadiusX="2" RadiusY="2" />
                            <Rectangle Canvas.Left="6" Canvas.Top="4" Width="4" Height="12"
                                       Fill="{StaticResource Brush.Accent}" RadiusX="2" RadiusY="2" />
                            <Rectangle Canvas.Left="12" Canvas.Top="0" Width="4" Height="20"
                                       Fill="{StaticResource Brush.Accent}" RadiusX="2" RadiusY="2" />
                            <Rectangle Canvas.Left="18" Canvas.Top="5" Width="4" Height="10"
                                       Fill="{StaticResource Brush.Accent}" RadiusX="2" RadiusY="2" />
                            <Rectangle Canvas.Left="24" Canvas.Top="9" Width="4" Height="2"
                                       Fill="{StaticResource Brush.Accent}" RadiusX="2" RadiusY="2" />
                            <Rectangle Canvas.Left="30" Canvas.Top="7" Width="4" Height="6"
                                       Fill="{StaticResource Brush.Accent}" RadiusX="2" RadiusY="2" />
                        </Canvas>
                        <TextBlock Text="AudioPress"
                                   FontSize="{StaticResource FontSize.XLarge}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="Audio Compression Workstation"
                                   Style="{StaticResource Style.Placeholder}"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Separator DockPanel.Dock="Top" Margin="16,0" />

                <!-- Mode Selector -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,0">
                    <TextBlock Text="MODE"
                               Style="{StaticResource Style.Label}"
                               Margin="8,0,0,10" />

                    <!-- Compress Tab -->
                    <Border x:Name="CompressModeBtn"
                            CornerRadius="{StaticResource Radius.Medium}"
                            Padding="14,11"
                            Cursor="Hand"
                            Margin="0,0,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompressMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding SetCompressModeCommand}" />
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal">
                            <!-- Compress icon (↓ arrow with lines) -->
                            <Canvas Width="18" Height="18" VerticalAlignment="Center">
                                <Line X1="9" Y1="2" X2="9" Y2="12"
                                      StrokeThickness="1.8" StrokeEndLineCap="Round">
                                    <Line.Stroke>
                                        <SolidColorBrush>
                                            <SolidColorBrush.Color>
                                                <Binding Path="IsCompressMode">
                                                    <Binding.Converter>
                                                        <conv:BoolToVisibilityConverter />
                                                    </Binding.Converter>
                                                </Binding>
                                            </SolidColorBrush.Color>
                                        </SolidColorBrush>
                                    </Line.Stroke>
                                </Line>
                                <Polyline Points="5,8 9,13 13,8"
                                          StrokeThickness="1.8" StrokeLineJoin="Round"
                                          StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                          Stroke="{StaticResource Brush.Accent}" />
                                <Line X1="3" Y1="16" X2="15" Y2="16"
                                      StrokeThickness="1.8" StrokeEndLineCap="Round"
                                      Stroke="{StaticResource Brush.Accent}" />
                            </Canvas>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Compress">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCompressMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Audio → Compressed"
                                           Style="{StaticResource Style.Placeholder}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Decompress Tab -->
                    <Border x:Name="DecompressModeBtn"
                            CornerRadius="{StaticResource Radius.Medium}"
                            Padding="14,11"
                            Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDecompressMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.AccentMuted}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding SetDecompressModeCommand}" />
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="18" Height="18" VerticalAlignment="Center">
                                <Polyline Points="5,5 9,2 13,5"
                                          StrokeThickness="1.8" StrokeLineJoin="Round"
                                          StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                          Stroke="{StaticResource Brush.TextMuted}" />
                                <Line X1="9" Y1="2" X2="9" Y2="12"
                                      StrokeThickness="1.8" StrokeEndLineCap="Round"
                                      Stroke="{StaticResource Brush.TextMuted}" />
                                <Line X1="3" Y1="16" X2="15" Y2="16"
                                      StrokeThickness="1.8" StrokeEndLineCap="Round"
                                      Stroke="{StaticResource Brush.TextMuted}" />
                            </Canvas>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Decompress">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDecompressMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Compressed → Audio"
                                           Style="{StaticResource Style.Placeholder}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Margin="16,20" />

                <!-- Activity Log -->
                <StackPanel DockPanel.Dock="Top" Margin="16,0,16,0" Height="180">
                    <TextBlock Text="ACTIVITY LOG"
                               Style="{StaticResource Style.Label}"
                               Margin="8,0,0,10" />
                    <Border Style="{StaticResource Style.Card}"
                            Padding="12"
                            Height="150"
                            BorderBrush="{StaticResource Brush.BorderSubtle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Style.LogEntry}"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- Version stamp pinned to bottom -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0.0"
                           Style="{StaticResource Style.Placeholder}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />

            </DockPanel>
        </Border>

        <!-- =====================================================
             MAIN CONTENT AREA
        ====================================================== -->
        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Header bar -->
                <RowDefinition Height="24" />    <!-- gap -->
                <RowDefinition Height="*" />     <!-- Content -->
                <RowDefinition Height="16" />    <!-- gap -->
                <RowDefinition Height="Auto" />  <!-- Bottom strip (progress + results) -->
            </Grid.RowDefinitions>

            <!-- ─────────────────────────────────────────────
                 ROW 0 — PAGE HEADER
            ────────────────────────────────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        FontSize="{StaticResource FontSize.XLarge}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Style.SectionHeading}">
                                <Setter Property="Text" Value="Compress Audio" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDecompressMode}" Value="True">
                                        <Setter Property="Text" Value="Decompress Audio" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Style.Placeholder}">
                                <Setter Property="Text"
                                        Value="Load an audio file and choose an algorithm to compress it." />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDecompressMode}" Value="True">
                                        <Setter Property="Text"
                                                Value="Load a compressed file to decompress and play it back." />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Reset button (top-right) -->
                <Button Grid.Column="1"
                        Content="↺  Reset"
                        Style="{StaticResource Style.Button.Danger}"
                        Command="{Binding ResetCommand}"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- ─────────────────────────────────────────────
                 ROW 2 — MAIN CONTENT (3-column layout)
                 Col 0: file drop + file info (flex)
                 Col 1: algorithm + settings (fixed)
                 Col 2: playback + compressed info (fixed)
            ────────────────────────────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="260" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <!-- ══════════════════════════════════════════
                     COLUMN 0 — FILE PANEL
                     (Drop zone + source file info)
                ═══════════════════════════════════════════ -->
                <DockPanel Grid.Column="0">

                    <!-- ── Drop Zone ───────────────────────── -->
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource Style.DropZone}"
                            Height="210"
                            AllowDrop="True"
                            DragEnter="FileDropBorder_OnDragEnter"
                            Drop="FileDropBorder_OnDrop">
                        <!-- Dashed border effect using a rectangle with StrokeDashArray -->
                        <Border CornerRadius="{StaticResource Radius.Large}"
                                BorderThickness="1.5"
                                Margin="-1">
                            <Border.BorderBrush>
                                <DrawingBrush Viewport="0,0,12,12" ViewportUnits="Absolute" TileMode="Tile">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,12,12" />
                                            </GeometryDrawing.Geometry>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="{StaticResource Brush.Border}"
                                                     Thickness="1.5"
                                                     DashStyle="{x:Static DashStyles.Dash}" />
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Border.BorderBrush>
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">

                                <!-- Waveform / file icon -->
                                <Canvas Width="52" Height="36"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,16">
                                    <Rectangle Canvas.Left="0" Canvas.Top="16" Width="6" Height="4"
                                               Fill="{StaticResource Brush.TextMuted}" RadiusX="3" RadiusY="3" />
                                    <Rectangle Canvas.Left="8" Canvas.Top="10" Width="6" Height="16"
                                               Fill="{StaticResource Brush.TextMuted}" RadiusX="3" RadiusY="3" />
                                    <Rectangle Canvas.Left="16" Canvas.Top="0" Width="6" Height="36"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="3" RadiusY="3" />
                                    <Rectangle Canvas.Left="24" Canvas.Top="8" Width="6" Height="20"
                                               Fill="{StaticResource Brush.TextMuted}" RadiusX="3" RadiusY="3" />
                                    <Rectangle Canvas.Left="32" Canvas.Top="14" Width="6" Height="8"
                                               Fill="{StaticResource Brush.TextMuted}" RadiusX="3" RadiusY="3" />
                                    <Rectangle Canvas.Left="40" Canvas.Top="11" Width="6" Height="14"
                                               Fill="{StaticResource Brush.TextMuted}" RadiusX="3" RadiusY="3" />
                                    <Rectangle Canvas.Left="48" Canvas.Top="17" Width="4" Height="2"
                                               Fill="{StaticResource Brush.TextMuted}" RadiusX="2" RadiusY="2" />
                                </Canvas>

                                <!-- Compress mode drop text -->
                                <StackPanel
                                    Visibility="{Binding IsCompressMode,
                                                Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Drop audio file here"
                                               FontSize="{StaticResource FontSize.Medium}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text=".wav · .mp3"
                                               Style="{StaticResource Style.Placeholder}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <!-- Decompress mode drop text -->
                                <StackPanel
                                    Visibility="{Binding IsDecompressMode,
                                                Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Drop compressed file here"
                                               FontSize="{StaticResource FontSize.Medium}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text=".dpcm · .adm · .dm · .nlq · .pdc"
                                               Style="{StaticResource Style.Placeholder}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <!-- Browse button -->
                                <Button Margin="0,14,0,0"
                                        HorizontalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Style.Button.Secondary}">
                                            <Setter Property="Content" Value="Browse Audio File" />
                                            <Setter Property="Command" Value="{Binding OpenAudioCommand}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDecompressMode}" Value="True">
                                                    <Setter Property="Content" Value="Browse Compressed File" />
                                                    <Setter Property="Command" Value="{Binding OpenCompressedCommand}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- ── Source File Info Card ──────────── -->
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource Style.Card}"
                            Margin="0,16,0,0"
                            Visibility="{Binding IsCompressMode,
                                         Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="SOURCE FILE"
                                       Style="{StaticResource Style.Label}"
                                       Margin="0,0,0,14" />

                            <!-- File name row -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- File icon -->
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        Background="{StaticResource Brush.SurfaceHighlight}"
                                        CornerRadius="{StaticResource Radius.Small}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="♪"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.AccentDim}" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SourceFileName}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SourceFileSize}"
                                               Style="{StaticResource Style.Placeholder}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>

                            <!-- Metadata chips -->
                            <UniformGrid Columns="3" HorizontalAlignment="Stretch">
                                <!-- Sample Rate -->
                                <Border Style="{StaticResource Style.InfoChip}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="SAMPLE RATE"
                                                   Style="{StaticResource Style.Label}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding SourceSampleRate}"
                                                   Style="{StaticResource Style.StatValue}"
                                                   FontSize="{StaticResource FontSize.Body}" />
                                    </StackPanel>
                                </Border>
                                <!-- Channels -->
                                <Border Style="{StaticResource Style.InfoChip}" Margin="3,0">
                                    <StackPanel>
                                        <TextBlock Text="CHANNELS"
                                                   Style="{StaticResource Style.Label}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding SourceChannels}"
                                                   Style="{StaticResource Style.StatValue}"
                                                   FontSize="{StaticResource FontSize.Body}" />
                                    </StackPanel>
                                </Border>
                                <!-- Bit Depth -->
                                <Border Style="{StaticResource Style.InfoChip}" Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="BIT DEPTH"
                                                   Style="{StaticResource Style.Label}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding SourceBitsPerSample}"
                                                   Style="{StaticResource Style.StatValue}"
                                                   FontSize="{StaticResource FontSize.Body}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- ── Compressed File Info Card (decompress mode) ─── -->
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource Style.Card}"
                            Margin="0,16,0,0"
                            Visibility="{Binding IsDecompressMode,
                                         Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="COMPRESSED FILE"
                                       Style="{StaticResource Style.Label}"
                                       Margin="0,0,0,14" />

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        Background="{StaticResource Brush.AmberMuted}"
                                        CornerRadius="{StaticResource Radius.Small}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="⚡"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.Amber}" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CompressedFileName}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding CompressedFileSize}"
                                               Style="{StaticResource Style.Placeholder}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>

                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource Style.InfoChip}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="ALGORITHM"
                                                   Style="{StaticResource Style.Label}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding CompressedAlgorithmName}"
                                                   Style="{StaticResource Style.StatValue}"
                                                   FontSize="{StaticResource FontSize.Body}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Style.InfoChip}" Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="FILE SIZE"
                                                   Style="{StaticResource Style.Label}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding CompressedFileSize}"
                                                   Style="{StaticResource Style.StatValue}"
                                                   FontSize="{StaticResource FontSize.Body}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Spacer -->
                    <Border DockPanel.Dock="Top" Height="0" />
                </DockPanel>

                <!-- ══════════════════════════════════════════
                     COLUMN 2 — ALGORITHM & SETTINGS
                     (only visible in Compress mode)
                ═══════════════════════════════════════════ -->
                <DockPanel Grid.Column="2"
                           Visibility="{Binding IsCompressMode,
                                        Converter={StaticResource BoolToVisibility}}">

                    <!-- Algorithm Selector Card -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource Style.Card}">
                        <StackPanel>
                            <TextBlock Text="ALGORITHM"
                                       Style="{StaticResource Style.Label}"
                                       Margin="0,0,0,12" />
                            <ComboBox Style="{StaticResource Style.ComboBox}"
                                      ItemsSource="{Binding Algorithms}"
                                      SelectedItem="{Binding SelectedAlgorithm}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Algorithm Settings Card -->
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource Style.Card}"
                            Margin="0,16,0,0"
                            Visibility="{Binding AlgorithmSettingsViewModel,
                                         Converter={StaticResource NullToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="SETTINGS"
                                       Style="{StaticResource Style.Label}"
                                       Margin="0,0,0,16" />

                            <!-- Dynamic settings panel -->
                            <!-- Each algorithm's settings VM exposes its own properties.
                                 Replace this placeholder with a DataTemplate selector
                                 or typed ContentPresenter per algorithm. -->
                            <ContentPresenter Content="{Binding AlgorithmSettingsViewModel}">
                                <ContentPresenter.ContentTemplate>
                                    <DataTemplate DataType="{x:Type vm:AlgorithmSettingsViewModel}">
                                        <!-- PLACEHOLDER settings panel.
                                             Replace with DataTemplateSelector or
                                             algorithm-specific UserControls. -->
                                        <StackPanel>
                                            <TextBlock Text="PARAMETER 1"
                                                       Style="{StaticResource Style.Label}"
                                                       Margin="0,0,0,6" />
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="50" />
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0"
                                                        Style="{StaticResource Style.Slider}"
                                                        Minimum="1" Maximum="256"
                                                        Value="{Binding Setting1}"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Setting1, StringFormat='{}{0:F0}'}"
                                                           Style="{StaticResource Style.StatValue}"
                                                           FontSize="{StaticResource FontSize.Body}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </Grid>

                                            <TextBlock Text="PARAMETER 2"
                                                       Style="{StaticResource Style.Label}"
                                                       Margin="0,16,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="50" />
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0"
                                                        Style="{StaticResource Style.Slider}"
                                                        Minimum="1" Maximum="1000"
                                                        Value="{Binding Setting2}"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Setting2, StringFormat='{}{0:F0}'}"
                                                           Style="{StaticResource Style.StatValue}"
                                                           FontSize="{StaticResource FontSize.Body}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentPresenter.ContentTemplate>
                            </ContentPresenter>
                        </StackPanel>
                    </Border>

                    <!-- Spacer -->
                    <Border DockPanel.Dock="Top" Height="0" />
                </DockPanel>

                <!-- ══════════════════════════════════════════
                     COLUMN 4 — PLAYBACK + ACTION CONTROLS
                ═══════════════════════════════════════════ -->
                <DockPanel Grid.Column="4">

                    <!-- Playback Card -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource Style.Card}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,16">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource Style.Label}">
                                        <Setter Property="Text" Value="PLAYBACK" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDecompressMode}"
                                                         Value="True">
                                                <Setter Property="Text" Value="DECOMPRESSED PLAYBACK" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Visualizer placeholder (waveform bars) -->
                            <Border Height="56"
                                    Background="{StaticResource Brush.SurfaceHighlight}"
                                    CornerRadius="{StaticResource Radius.Medium}"
                                    Margin="0,0,0,16"
                                    ClipToBounds="True">
                                <Canvas>
                                    <!-- Static decorative waveform bars -->
                                    <Rectangle Canvas.Left="4" Canvas.Top="22" Width="5" Height="12"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="11" Canvas.Top="14" Width="5" Height="28"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="18" Canvas.Top="8" Width="5" Height="40"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="25" Canvas.Top="18" Width="5" Height="20"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="32" Canvas.Top="10" Width="5" Height="36"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="39" Canvas.Top="20" Width="5" Height="16"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="46" Canvas.Top="4" Width="5" Height="48"
                                               Fill="{StaticResource Brush.Accent}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="53" Canvas.Top="12" Width="5" Height="32"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="60" Canvas.Top="20" Width="5" Height="16"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="67" Canvas.Top="16" Width="5" Height="24"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="74" Canvas.Top="6" Width="5" Height="44"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="81" Canvas.Top="22" Width="5" Height="12"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="88" Canvas.Top="14" Width="5" Height="28"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="95" Canvas.Top="18" Width="5" Height="20"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="102" Canvas.Top="10" Width="5" Height="36"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="109" Canvas.Top="22" Width="5" Height="12"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="116" Canvas.Top="16" Width="5" Height="24"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="123" Canvas.Top="8" Width="5" Height="40"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="130" Canvas.Top="20" Width="5" Height="16"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="137" Canvas.Top="14" Width="5" Height="28"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="144" Canvas.Top="22" Width="5" Height="12"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="151" Canvas.Top="18" Width="5" Height="20"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="158" Canvas.Top="12" Width="5" Height="32"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="165" Canvas.Top="20" Width="5" Height="16"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="172" Canvas.Top="24" Width="5" Height="8"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="179" Canvas.Top="16" Width="5" Height="24"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="186" Canvas.Top="18" Width="5" Height="20"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="193" Canvas.Top="22" Width="5" Height="12"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="200" Canvas.Top="14" Width="5" Height="28"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="207" Canvas.Top="20" Width="5" Height="16"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="214" Canvas.Top="10" Width="5" Height="36"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="221" Canvas.Top="22" Width="5" Height="12"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="228" Canvas.Top="18" Width="5" Height="20"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="235" Canvas.Top="8" Width="5" Height="40"
                                               Fill="{StaticResource Brush.AccentDim}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="242" Canvas.Top="22" Width="5" Height="12"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <Rectangle Canvas.Left="249" Canvas.Top="14" Width="5" Height="28"
                                               Fill="{StaticResource Brush.Border}" RadiusX="2" RadiusY="2" />
                                    <TextBlock Text="Waveform"
                                               Style="{StaticResource Style.Placeholder}"
                                               Canvas.Left="0" Canvas.Top="0"
                                               Opacity="0" />
                                </Canvas>
                            </Border>

                            <!-- Transport Controls — COMPRESS MODE -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding IsCompressMode,
                                                     Converter={StaticResource BoolToVisibility}}">
                                <!-- Stop -->
                                <Button Style="{StaticResource Style.Button.Icon}"
                                        Command="{Binding StopCommand}"
                                        ToolTip="Stop">
                                    <Canvas Width="14" Height="14">
                                        <Rectangle Width="14" Height="14"
                                                   Fill="{StaticResource Brush.TextSecondary}"
                                                   RadiusX="2" RadiusY="2" />
                                    </Canvas>
                                </Button>
                                <!-- Play / Pause toggle -->
                                <Button
                                    Margin="12,0"
                                    ToolTip="Play / Pause">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource Style.Button.Play}">
                                            <Setter Property="Command" Value="{Binding PlayCommand}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlayingSource}" Value="True">
                                                    <Setter Property="Command" Value="{Binding PauseCommand}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <!-- Play triangle -->
                                    <Canvas Width="16" Height="16">
                                        <!-- Play icon -->
                                        <Polygon
                                            Visibility="{Binding IsPlayingSource,
                                                              Converter={StaticResource BoolToVisibility},
                                                              ConverterParameter=Invert}"
                                            Points="2,1 14,8 2,15"
                                            Fill="{StaticResource Brush.Accent}" />
                                        <!-- Pause icon -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsPlayingSource,
                                                                 Converter={StaticResource BoolToVisibility}}">
                                            <Rectangle Width="4" Height="14"
                                                       Fill="{StaticResource Brush.Accent}"
                                                       RadiusX="1" RadiusY="1" />
                                            <Rectangle Width="4" Height="14" Margin="4,0,0,0"
                                                       Fill="{StaticResource Brush.Accent}"
                                                       RadiusX="1" RadiusY="1" />
                                        </StackPanel>
                                    </Canvas>
                                </Button>
                                <!-- Skip-to-end placeholder -->
                                <Button Style="{StaticResource Style.Button.Icon}"
                                        IsEnabled="False"
                                        ToolTip="Skip">
                                    <Canvas Width="14" Height="14">
                                        <Polygon Points="0,0 10,7 0,14"
                                                 Fill="{StaticResource Brush.TextMuted}" />
                                        <Rectangle Canvas.Left="11" Width="3" Height="14"
                                                   Fill="{StaticResource Brush.TextMuted}"
                                                   RadiusX="1" RadiusY="1" />
                                    </Canvas>
                                </Button>
                            </StackPanel>

                            <!-- Transport Controls — DECOMPRESS MODE -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding IsDecompressMode,
                                                     Converter={StaticResource BoolToVisibility}}">
                                <Button Style="{StaticResource Style.Button.Icon}"
                                        Command="{Binding StopDecompressedCommand}"
                                        ToolTip="Stop">
                                    <Canvas Width="14" Height="14">
                                        <Rectangle Width="14" Height="14"
                                                   Fill="{StaticResource Brush.TextSecondary}"
                                                   RadiusX="2" RadiusY="2" />
                                    </Canvas>
                                </Button>
                                <Button Style="{StaticResource Style.Button.Play}"
                                        Margin="12,0"
                                        Command="{Binding PlayDecompressedCommand}"
                                        ToolTip="Play decompressed audio">
                                    <Canvas Width="16" Height="16">
                                        <Polygon Points="2,1 14,8 2,15"
                                                 Fill="{StaticResource Brush.Accent}" />
                                    </Canvas>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Action Button Card -->
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource Style.Card}"
                            Margin="0,16,0,0">
                        <StackPanel>

                            <!-- COMPRESS ACTION -->
                            <StackPanel
                                Visibility="{Binding IsCompressMode,
                                                     Converter={StaticResource BoolToVisibility}}">
                                <Button Content="▶  Compress"
                                        Style="{StaticResource Style.Button.Primary}"
                                        Command="{Binding CompressCommand}"
                                        HorizontalAlignment="Stretch"
                                        FontSize="{StaticResource FontSize.Medium}" />
                                <Button Content="✕  Cancel"
                                        Style="{StaticResource Style.Button.Danger}"
                                        Command="{Binding CancelCompressionCommand}"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Stretch"
                                        Visibility="{Binding IsCompressing,
                                                     Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>

                            <!-- DECOMPRESS ACTION -->
                            <StackPanel
                                Visibility="{Binding IsDecompressMode,
                                                     Converter={StaticResource BoolToVisibility}}">
                                <Button Content="▶  Decompress"
                                        Style="{StaticResource Style.Button.Primary}"
                                        Command="{Binding DecompressCommand}"
                                        HorizontalAlignment="Stretch"
                                        FontSize="{StaticResource FontSize.Medium}" />
                                <Button Content="✕  Cancel"
                                        Style="{StaticResource Style.Button.Danger}"
                                        Command="{Binding CancelDecompressionCommand}"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Stretch"
                                        Visibility="{Binding IsDecompressing,
                                                     Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Spacer -->
                    <Border DockPanel.Dock="Top" Height="0" />
                </DockPanel>

            </Grid>

            <!-- ─────────────────────────────────────────────
                 ROW 4 — PROGRESS + RESULTS STRIP
            ────────────────────────────────────────────── -->
            <Border Grid.Row="4"
                    Style="{StaticResource Style.Card}"
                    Padding="24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Progress section -->
                    <StackPanel Grid.Column="0">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Style.Label}">
                                        <Setter Property="Text" Value="COMPRESSION PROGRESS" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDecompressMode}" Value="True">
                                                <Setter Property="Text" Value="DECOMPRESSION PROGRESS" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding OperationProgress,
                                              Converter={StaticResource ProgressToPercent}}"
                                       Style="{StaticResource Style.StatValue}"
                                       FontSize="{StaticResource FontSize.Body}" />
                        </Grid>
                        <ProgressBar Style="{StaticResource Style.ProgressBar}"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding OperationProgress}" />

                        <!-- Live metrics row -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Border Style="{StaticResource Style.InfoChip}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SPEED "
                                               Style="{StaticResource Style.Label}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ProcessingSpeed}"
                                               Style="{StaticResource Style.StatValue}"
                                               FontSize="{StaticResource FontSize.Small}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <!-- Live ratio — compress mode only -->
                            <Border Style="{StaticResource Style.InfoChip}"
                                    Visibility="{Binding IsCompressMode,
                                                 Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LIVE RATIO "
                                               Style="{StaticResource Style.Label}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LiveCompressionRatio}"
                                               Style="{StaticResource Style.StatValue}"
                                               FontSize="{StaticResource FontSize.Small}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Grid.Column="1"
                               Width="1"
                               Fill="{StaticResource Brush.Border}"
                               Margin="0,4" />

                    <!-- Right: Final results (shown after completion) -->
                    <UniformGrid Grid.Column="2" Columns="4" VerticalAlignment="Center">

                        <!-- Final Ratio -->
                        <StackPanel Margin="16,0"
                                    Visibility="{Binding IsCompressMode,
                                                 Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="FINAL RATIO"
                                       Style="{StaticResource Style.Label}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding FinalCompressionRatio}"
                                       Style="{StaticResource Style.StatValue}" />
                        </StackPanel>

                        <!-- Space Saved -->
                        <StackPanel Margin="16,0"
                                    Visibility="{Binding IsCompressMode,
                                                 Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="SPACE SAVED"
                                       Style="{StaticResource Style.Label}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SpaceSaved}"
                                       Style="{StaticResource Style.StatValue}"
                                       Foreground="{StaticResource Brush.Success}" />
                        </StackPanel>

                        <!-- SNR dB -->
                        <StackPanel Margin="16,0"
                                    Visibility="{Binding IsCompressMode,
                                                 Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="SNR"
                                       Style="{StaticResource Style.Label}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SnrDb}"
                                       Style="{StaticResource Style.StatValue}"
                                       Foreground="{StaticResource Brush.Amber}" />
                        </StackPanel>

                        <!-- Duration -->
                        <StackPanel Margin="16,0">
                            <TextBlock >
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Style.Label}">
                                        <Setter Property="Text" Value="COMPRESS TIME" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDecompressMode}" Value="True">
                                                <Setter Property="Text" Value="DECOMPRESS TIME" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding FinalDuration}"
                                       Style="{StaticResource Style.StatValue}" />
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>